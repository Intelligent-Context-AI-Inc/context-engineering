          "definition_file": "docs/definitions/context-structuring.md",
          "architecture_file": "docs/architecture/context-structuring-layer.md"
        },
        {
          "name": "Context Delivery Layer",
          "description": "Delivers assembled context to AI systems",
          "definition_file": "docs/definitions/context-delivery.md",
          "architecture_file": "docs/architecture/context-delivery-layer.md"
        }
      ]
    },
